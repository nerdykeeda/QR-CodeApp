{
  "version": 2,
  "buildCommand": "echo 'Static build complete'",
  "outputDirectory": ".",
  "builds": [
    {
      "src": "server-simple.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.{html,css,js,png,jpg,jpeg,svg,ico,json}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server-simple.js"
    },
    {
      "src": "/r/(.*)",
      "dest": "/server-simple.js"
    },
    {
      "src": "/health",
      "dest": "/server-simple.js"
    },
    {
      "src": "/(.*\\.(html|css|js|png|jpg|jpeg|svg|ico|json))",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "server-simple.js": {
      "maxDuration": 10
    }
  }
}
