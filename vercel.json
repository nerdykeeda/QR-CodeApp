{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "server-simple.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server-simple.js"
    },
    {
      "source": "/r/(.*)",
      "destination": "/server-simple.js"
    },
    {
      "source": "/health",
      "destination": "/server-simple.js"
    }
  ],
  "functions": {
    "server-simple.js": {
      "maxDuration": 10
    }
  }
}
