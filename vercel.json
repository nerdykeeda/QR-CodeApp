{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "server-simple.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server-simple.js"
    },
    {
      "src": "/r/(.*)",
      "dest": "/server-simple.js"
    },
    {
      "src": "/health",
      "dest": "/server-simple.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "functions": {
    "server-simple.js": {
      "maxDuration": 10
    }
  }
}
